# Maryland Civic Hub — Production Environment Variables
# Copy this file to .env on your VPS and fill in the real values.

# --- Required for both frontend build and backend runtime ---
PORT=3001
BASE_PATH=/
API_BASE_URL=https://politician.api.bawlmorean.com/api
VITE_API_BASE_URL=https://politician.api.bawlmorean.com/api

# --- PostgreSQL (Docker Compose on same VPS) ---
# DATABASE_URL must match the docker-compose.yml credentials.
# Default from docker-compose: postgres://civic:changeme@localhost:5432/civic_hub
DATABASE_URL=postgresql://civic:changeme@localhost:5432/civic_hub
POSTGRES_USER=civic
POSTGRES_PASSWORD=changeme
POSTGRES_DB=civic_hub

# --- External API keys ---
CONGRESS_API_KEY=
OPENSTATES_API_KEY=
GOOGLE_CIVIC_API_KEY=

# --- CORS (must match the frontend domain exactly) ---
CORS_ORIGIN=https://politician.bawlmorean.com
